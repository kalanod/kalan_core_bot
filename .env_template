# Telegram
BOT_TOKEN=123456:replace_with_telegram_bot_token

# Application
APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kalan_core_bot
POSTGRES_USER=kalan_core_bot
POSTGRES_PASSWORD=change_me

# SQLAlchemy-compatible DSN. For docker compose use the postgres service name as host.
DATABASE_URL=postgresql+asyncpg://kalan_core_bot:change_me@postgres:5432/kalan_core_bot

# Telegram username allow-list as a JSON array of strings. Users not listed receive restricted.png on /start.
ALLOW_LIST=["kalanod", "misha"]
